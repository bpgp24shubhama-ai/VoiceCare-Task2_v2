# OpenAI API Key (GPT-5 with web search)
OPENAI_API_KEY=your_openai_api_key_here

# SEMrush API Key — https://developer.semrush.com/api/
# Enables real keyword volumes, traffic data, backlink profiles, and SERP analysis.
# When set, ALL competitor/GEO/content analyses are grounded in hard SEMrush numbers.
SEMRUSH_API_KEY=your_semrush_api_key_here

# Agent Configuration
AGENT_LOG_LEVEL=INFO
CONTENT_AUTO_POST=false
